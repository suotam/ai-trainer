      "service": {"type": "String", "example": "ai-trainer-backend"},
      "version": {"type": "String", "example": "0.0.1-dev"}
    }
  },
  "backendStatusNotReady": "Backend is running but not ready to accept traffic",
  "@backendStatusNotReady": {
    "description": "Liveness succeeded but readiness returned not-ready."
  },
  "backendStatusUnavailable": "Backend is not reachable",
  "@backendStatusUnavailable": {
    "description": "Safe failure message; no internal details."
